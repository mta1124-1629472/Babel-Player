<Window x:Class="BabelPlayer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BabelPlayer.UI"
        Title="Babel Player"
        Width="1280"
        Height="760"
        MinWidth="960"
        MinHeight="600"
        Background="#0B1016"
        KeyDown="Window_KeyDown"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#C9182330" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#2C4158" />
        <SolidColorBrush x:Key="MenuChipBrush" Color="#223449" />
        <SolidColorBrush x:Key="MenuChipHoverBrush" Color="#2E4A66" />
        <SolidColorBrush x:Key="MenuChipPressedBrush" Color="#375777" />
        <SolidColorBrush x:Key="MenuChipBorderBrush" Color="#496887" />
        <SolidColorBrush x:Key="StatusBadgeBrush" Color="#162433" />
        <SolidColorBrush x:Key="StatusBadgeBorderBrush" Color="#2D455D" />
        <SolidColorBrush x:Key="TransportBrush" Color="#D3101820" />
        <SolidColorBrush x:Key="TransportBorderBrush" Color="#2A4358" />
        <SolidColorBrush x:Key="ControlButtonBrush" Color="#22354A" />
        <SolidColorBrush x:Key="ControlButtonHoverBrush" Color="#2D4966" />
        <SolidColorBrush x:Key="ControlButtonPressedBrush" Color="#37597B" />
        <SolidColorBrush x:Key="ControlButtonBorderBrush" Color="#4C6B89" />

        <Style x:Key="TopMenuStyle" TargetType="{x:Type Menu}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#F6FBFF" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Menu}">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="#F6FBFF" />
            <Setter Property="Background" Value="{StaticResource MenuChipBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MenuChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border x:Name="TopBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    SnapsToDevicePixels="True">
                                <Grid Margin="16,9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#B5CDE4"
                                               FontSize="11"
                                               Text="▾" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,8,0,0"
                                        Padding="6"
                                        Background="#F2F7FB"
                                        BorderBrush="#B5C8D8"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20"
                                                          ShadowDepth="4"
                                                          Opacity="0.28"
                                                          Color="#000000" />
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopBorder" Property="Background" Value="{StaticResource MenuChipHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopBorder" Property="Background" Value="{StaticResource MenuChipPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border x:Name="SubItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CheckGlyph"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="#215B8F"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Text="✓"
                                               Visibility="Collapsed" />
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="ArrowGlyph"
                                               Grid.Column="2"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#62778D"
                                               Text="›"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Margin="8,0,0,0"
                                        Padding="6"
                                        Background="#F2F7FB"
                                        BorderBrush="#B5C8D8"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18"
                                                          ShadowDepth="4"
                                                          Opacity="0.24"
                                                          Color="#000000" />
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="SubItemBorder" Property="Background" Value="#D9E9F5" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#F5FAFF" />
            <Setter Property="Background" Value="{StaticResource ControlButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14,12"
                CornerRadius="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Opacity="0.25"
                                  Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#111D29"
                            BorderBrush="#314A61"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14,9"
                            Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="BABEL PLAYER"
                                       Foreground="#9FC2E0"
                                       FontSize="10"
                                       FontWeight="Bold" />
                            <TextBlock Text="Local subtitle workstation"
                                       Foreground="#F4FAFF"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Menu Style="{StaticResource TopMenuStyle}"
                          ItemContainerStyle="{StaticResource TopMenuItemStyle}"
                          VerticalAlignment="Center">
                        <Menu.Resources>
                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource SubMenuItemStyle}" />
                            <Style TargetType="{x:Type Separator}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Separator}">
                                            <Border Height="1"
                                                    Margin="10,6"
                                                    Background="#D3DEE7" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Menu.Resources>
                        <MenuItem Header="Subtitles" Style="{StaticResource TopMenuItemStyle}">
                            <MenuItem Name="ShowSubtitlesMenuItem"
                                      Header="Show Subtitles"
                                      IsCheckable="True"
                                      IsChecked="True"
                                      Checked="ShowSubtitlesMenuItem_Checked"
                                      Unchecked="ShowSubtitlesMenuItem_Unchecked" />
                            <MenuItem Header="Style">
                                <MenuItem Header="Larger Text" Click="IncreaseSubtitleFontMenuItem_Click" />
                                <MenuItem Header="Smaller Text" Click="DecreaseSubtitleFontMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="More Background" Click="IncreaseSubtitleBackgroundMenuItem_Click" />
                                <MenuItem Header="Less Background" Click="DecreaseSubtitleBackgroundMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="Raise Subtitles" Click="RaiseSubtitlesMenuItem_Click" />
                                <MenuItem Header="Lower Subtitles" Click="LowerSubtitlesMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="Translation Color">
                                    <MenuItem Header="White" Tag="#FFFFFF" Click="TranslationColorMenuItem_Click" />
                                    <MenuItem Header="Amber" Tag="#FFD580" Click="TranslationColorMenuItem_Click" />
                                    <MenuItem Header="Cyan" Tag="#BFEFFF" Click="TranslationColorMenuItem_Click" />
                                </MenuItem>
                            </MenuItem>
                            <MenuItem Header="Render Mode">
                                <MenuItem Name="SubtitleRenderOffMenuItem"
                                          Header="Off"
                                          Tag="off"
                                          IsCheckable="True"
                                          Click="SubtitleRenderModeMenuItem_Click" />
                                <MenuItem Name="SubtitleRenderSourceOnlyMenuItem"
                                          Header="Source Only"
                                          Tag="source"
                                          IsCheckable="True"
                                          Click="SubtitleRenderModeMenuItem_Click" />
                                <MenuItem Name="SubtitleRenderTranslationOnlyMenuItem"
                                          Header="Translation Only"
                                          Tag="translation"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="SubtitleRenderModeMenuItem_Click" />
                                <MenuItem Name="SubtitleRenderDualMenuItem"
                                          Header="Dual"
                                          Tag="dual"
                                          IsCheckable="True"
                                          Click="SubtitleRenderModeMenuItem_Click" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Open Subtitles" Click="OpenSubtitlesButton_Click" />
                            <Separator />
                            <MenuItem Header="Transcription Model">
                                <MenuItem Name="SubtitleModelLocalTinyMenuItem"
                                          Header="Local: Tiny (fastest)"
                                          Tag="local:tiny"
                                          IsCheckable="True"
                                          Click="SubtitleModelMenuItem_Click" />
                                <MenuItem Name="SubtitleModelLocalBaseMenuItem"
                                          Header="Local: Base (faster)"
                                          Tag="local:base"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="SubtitleModelMenuItem_Click" />
                                <MenuItem Name="SubtitleModelLocalSmallMenuItem"
                                          Header="Local: Small (better quality)"
                                          Tag="local:small"
                                          IsCheckable="True"
                                          Click="SubtitleModelMenuItem_Click" />
                                <Separator />
                                <MenuItem Name="SubtitleModelCloudMiniMenuItem"
                                          Header="Cloud: GPT-4o Mini Transcribe (faster)"
                                          Tag="cloud:gpt-4o-mini-transcribe"
                                          IsCheckable="True"
                                          Click="SubtitleModelMenuItem_Click" />
                                <MenuItem Name="SubtitleModelCloudGpt4oMenuItem"
                                          Header="Cloud: GPT-4o Transcribe"
                                          Tag="cloud:gpt-4o-transcribe"
                                          IsCheckable="True"
                                          Click="SubtitleModelMenuItem_Click" />
                                <MenuItem Name="SubtitleModelCloudWhisperMenuItem"
                                          Header="Cloud: Whisper-1"
                                          Tag="cloud:whisper-1"
                                          IsCheckable="True"
                                          Click="SubtitleModelMenuItem_Click" />
                            </MenuItem>
                            <MenuItem Header="Set OpenAI API Key" Click="SetOpenAiApiKeyMenuItem_Click" />
                        </MenuItem>
                        <MenuItem Header="Translation" Style="{StaticResource TopMenuItemStyle}">
                            <MenuItem Name="EnableTranslationForCurrentVideoMenuItem"
                                      Header="Translate Current Video"
                                      IsCheckable="True"
                                      IsChecked="False"
                                      Checked="EnableTranslationForCurrentVideoMenuItem_Checked"
                                      Unchecked="EnableTranslationForCurrentVideoMenuItem_Unchecked" />
                            <MenuItem Header="Target Language">
                                <MenuItem Name="TranslateTargetEnglishMenuItem"
                                          Header="English"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="TranslateTargetEnglishMenuItem_Click" />
                            </MenuItem>
                            <MenuItem Header="Auto-Translate Videos Not In">
                                <MenuItem Name="AutoTranslateNonEnglishMenuItem"
                                          Header="English"
                                          IsCheckable="True"
                                          IsChecked="False"
                                          Checked="AutoTranslateNonEnglishMenuItem_Checked"
                                          Unchecked="AutoTranslateNonEnglishMenuItem_Unchecked" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Translation Model">
                                <MenuItem Name="TranslationModelLocalHyMt18BMenuItem"
                                          Header="Local: HY-MT1.5 1.8B"
                                          Tag="local:hymt-1.8b"
                                          IsCheckable="True"
                                          Click="TranslationModelMenuItem_Click" />
                                <MenuItem Name="TranslationModelLocalHyMt7BMenuItem"
                                          Header="Local: HY-MT1.5 7B"
                                          Tag="local:hymt-7b"
                                          IsCheckable="True"
                                          Click="TranslationModelMenuItem_Click" />
                                <MenuItem Name="TranslationModelCloudOpenAiMenuItem"
                                          Header="Cloud: OpenAI GPT-5 Mini"
                                          Tag="cloud:gpt-5-mini"
                                          IsCheckable="True"
                                          Click="TranslationModelMenuItem_Click" />
                                <MenuItem Name="TranslationModelCloudGoogleMenuItem"
                                          Header="Cloud: Google Translate"
                                          Tag="cloud:google-translate"
                                          IsCheckable="True"
                                          Click="TranslationModelMenuItem_Click" />
                                <MenuItem Name="TranslationModelCloudDeepLMenuItem"
                                          Header="Cloud: DeepL API"
                                          Tag="cloud:deepl"
                                          IsCheckable="True"
                                          Click="TranslationModelMenuItem_Click" />
                                <MenuItem Name="TranslationModelCloudMicrosoftMenuItem"
                                          Header="Cloud: Microsoft Translator"
                                          Tag="cloud:microsoft-translator"
                                          IsCheckable="True"
                                          Click="TranslationModelMenuItem_Click" />
                            </MenuItem>
                            <MenuItem Header="Set llama.cpp Server Path" Click="SetLlamaCppServerPathMenuItem_Click" />
                            <MenuItem Header="Set OpenAI API Key" Click="SetOpenAiApiKeyMenuItem_Click" />
                            <MenuItem Header="Set Google Translate API Key" Click="SetGoogleTranslateApiKeyMenuItem_Click" />
                            <MenuItem Header="Set DeepL API Key" Click="SetDeepLApiKeyMenuItem_Click" />
                            <MenuItem Header="Set Microsoft Translator Credentials" Click="SetMicrosoftTranslatorCredentialsMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="Export EN SRT" Click="ExportButton_Click" />
                        </MenuItem>
                        <MenuItem Header="Playback" Style="{StaticResource TopMenuItemStyle}">
                            <MenuItem Name="AudioTracksMenuItem" Header="Audio Track" />
                            <MenuItem Name="EmbeddedSubtitleTracksMenuItem" Header="Embedded Subtitle Track" />
                            <Separator />
                            <MenuItem Header="Hardware Decoding">
                                <MenuItem Name="HardwareDecodingAutoMenuItem"
                                          Header="Auto (safe)"
                                          Tag="auto"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="HardwareDecodingMenuItem_Click" />
                                <MenuItem Name="HardwareDecodingD3D11MenuItem"
                                          Header="D3D11"
                                          Tag="d3d11"
                                          IsCheckable="True"
                                          Click="HardwareDecodingMenuItem_Click" />
                                <MenuItem Name="HardwareDecodingNvdecMenuItem"
                                          Header="NVDEC"
                                          Tag="nvdec"
                                          IsCheckable="True"
                                          Click="HardwareDecodingMenuItem_Click" />
                                <MenuItem Name="HardwareDecodingSoftwareMenuItem"
                                          Header="Software"
                                          Tag="software"
                                          IsCheckable="True"
                                          Click="HardwareDecodingMenuItem_Click" />
                            </MenuItem>
                            <MenuItem Header="Aspect Ratio">
                                <MenuItem Name="AspectRatioAutoMenuItem"
                                          Header="Auto"
                                          Tag="auto"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="AspectRatioMenuItem_Click" />
                                <MenuItem Name="AspectRatioWideMenuItem"
                                          Header="16:9"
                                          Tag="16:9"
                                          IsCheckable="True"
                                          Click="AspectRatioMenuItem_Click" />
                                <MenuItem Name="AspectRatioClassicMenuItem"
                                          Header="4:3"
                                          Tag="4:3"
                                          IsCheckable="True"
                                          Click="AspectRatioMenuItem_Click" />
                                <MenuItem Name="AspectRatioStretchMenuItem"
                                          Header="Fill"
                                          Tag="-1"
                                          IsCheckable="True"
                                          Click="AspectRatioMenuItem_Click" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Subtitle Delay -50 ms" Click="SubtitleDelayBackMenuItem_Click" />
                            <MenuItem Header="Subtitle Delay +50 ms" Click="SubtitleDelayForwardMenuItem_Click" />
                            <MenuItem Header="Reset Subtitle Delay" Click="ResetSubtitleDelayMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="Audio Delay -50 ms" Click="AudioDelayBackMenuItem_Click" />
                            <MenuItem Header="Audio Delay +50 ms" Click="AudioDelayForwardMenuItem_Click" />
                            <MenuItem Header="Reset Audio Delay" Click="ResetAudioDelayMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="Borderless Window" Click="BorderlessWindowMenuItem_Click" />
                            <MenuItem Header="Picture in Picture" Click="PictureInPictureMenuItem_Click" />
                            <MenuItem Header="Fullscreen" Click="FullscreenMenuItem_Click" />
                        </MenuItem>
                        <MenuItem Header="View" Style="{StaticResource TopMenuItemStyle}">
                            <MenuItem Name="ShowBrowserPanelMenuItem"
                                      Header="Show Browser Panel"
                                      IsCheckable="True"
                                      Click="ShowBrowserPanelMenuItem_Click" />
                            <MenuItem Name="ShowPlaylistPanelMenuItem"
                                      Header="Show Playlist Panel"
                                      IsCheckable="True"
                                      Click="ShowPlaylistPanelMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="Edit Shortcuts" Click="EditShortcutsMenuItem_Click" />
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Background="{StaticResource StatusBadgeBrush}"
                            BorderBrush="{StaticResource StatusBadgeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,8"
                            Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Accelerator"
                                       Foreground="#8FB3CF"
                                       FontSize="10"
                                       FontWeight="Bold" />
                            <TextBlock Name="HardwareStatusText"
                                       Foreground="#F4FAFF"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border Background="#111D29"
                            BorderBrush="#324A60"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,8"
                            MaxWidth="420">
                        <StackPanel>
                            <TextBlock Text="Session"
                                       Foreground="#8FB3CF"
                                       FontSize="10"
                                       FontWeight="Bold" />
                            <TextBlock Name="PlaybackStatusText"
                                       Foreground="#DDEAF5"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Name="PlaybackSurface"
              Grid.Row="1"
              Margin="0,10,0,0"
              MouseEnter="PlaybackSurface_MouseEnter"
              MouseLeave="PlaybackSurface_MouseLeave">
            <Grid.Background>
                <RadialGradientBrush Center="0.5,0.35" GradientOrigin="0.5,0.35" RadiusX="0.95" RadiusY="0.95">
                    <GradientStop Color="#1D2630" Offset="0" />
                    <GradientStop Color="#0A0F15" Offset="0.65" />
                    <GradientStop Color="#04070A" Offset="1" />
                </RadialGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BrowserColumn" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="PlaylistColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border x:Name="BrowserPanel"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="14"
                    CornerRadius="18"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Browser"
                               Foreground="#E6F2FC"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
                        <Button Name="AddFolderButton"
                                Content="Add Folder"
                                Style="{StaticResource TransportButtonStyle}"
                                Margin="0,0,8,0"
                                Click="AddFolderButton_Click" />
                        <Button Name="PinCurrentFolderButton"
                                Content="Pin"
                                Style="{StaticResource TransportButtonStyle}"
                                Click="PinCurrentFolderButton_Click" />
                    </StackPanel>
                    <TreeView Name="LibraryTreeView"
                              Grid.Row="2"
                              Background="Transparent"
                              Foreground="#EAF4FD"
                              SelectedItemChanged="LibraryTreeView_SelectedItemChanged"
                              MouseDoubleClick="LibraryTreeView_MouseDoubleClick" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <local:MpvPlayerControl x:Name="Player" />

                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="16"
                            MaxWidth="1080">
                    <Border Name="SubtitleOverlayContainer"
                            Margin="0,0,0,12"
                            Padding="22,14"
                            CornerRadius="18"
                            Background="#C8141C25"
                            BorderBrush="#6B8DA8"
                            BorderThickness="1"
                            MaxWidth="980">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="26"
                                              ShadowDepth="6"
                                              Opacity="0.28"
                                              Color="#000000" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Name="SubtitleSourceText"
                                       Foreground="#CCDAE8"
                                       FontSize="20"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                            <TextBlock Name="SubtitleText"
                                       Foreground="#F7FBFF"
                                       FontSize="29"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="Open a local video. Babel Player will auto-generate local captions if no .srt is found." />
                        </StackPanel>
                    </Border>

                    <Border Name="TransportPanel"
                            Padding="20,16"
                            CornerRadius="20"
                            Background="{StaticResource TransportBrush}"
                            BorderBrush="{StaticResource TransportBorderBrush}"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28"
                                              ShadowDepth="6"
                                              Opacity="0.3"
                                              Color="#000000" />
                        </Border.Effect>
                        <Grid Width="1000">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="CurrentTimeText"
                                           Grid.Column="0"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           Foreground="#F3F9FF"
                                           FontWeight="SemiBold"
                                           Text="00:00" />

                                <Slider Name="ProgressSlider"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        SmallChange="1"
                                        LargeChange="10"
                                        VerticalAlignment="Center"
                                        PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp"
                                        ValueChanged="ProgressSlider_ValueChanged" />

                                <TextBlock Name="DurationText"
                                           Grid.Column="2"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#C8D9E8"
                                           FontWeight="SemiBold"
                                           Text="00:00" />
                            </Grid>

                            <WrapPanel Grid.Row="1"
                                       HorizontalAlignment="Center"
                                       ItemHeight="40">
                                <Button Name="OpenVideoButton"
                                        Content="Open"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="OpenVideoButton_Click" />
                                <Button Name="PreviousPlaylistButton"
                                        Content="⏮"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="44"
                                        Height="40"
                                        Margin="0,0,10,10"
                                        Click="PreviousPlaylistButton_Click" />
                                <Button Name="NextPlaylistButton"
                                        Content="⏭"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="44"
                                        Height="40"
                                        Margin="0,0,10,10"
                                        Click="NextPlaylistButton_Click" />
                                <Button Name="FullscreenButton"
                                        Content="⛶"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="44"
                                        Height="40"
                                        Margin="0,0,10,10"
                                        Click="FullscreenButton_Click" />
                                <Button Name="PiPButton"
                                        Content="▣"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="44"
                                        Height="40"
                                        Margin="0,0,10,10"
                                        Click="PiPButton_Click" />
                                <Button Name="RewindButton"
                                        Content="⏪"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="RewindButton_Click" />
                                <Button Name="PreviousFrameButton"
                                        Content="⟨▌"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="PreviousFrameButton_Click" />
                                <Button Name="PlayPauseButton"
                                        Content="⏸"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="56"
                                        Height="40"
                                        Margin="0,0,10,10"
                                        Click="PlayPauseButton_Click" />
                                <Button Name="NextFrameButton"
                                        Content="▐⟩"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="NextFrameButton_Click" />
                                <Button Name="FastForwardButton"
                                        Content="⏩"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Click="FastForwardButton_Click" />
                                <TextBlock Text="Speed"
                                           VerticalAlignment="Center"
                                           Foreground="#D8E6F2"
                                           Margin="4,0,6,10" />
                                <ComboBox Name="PlaybackSpeedComboBox"
                                          Width="92"
                                          Margin="0,0,10,10"
                                          SelectionChanged="PlaybackSpeedComboBox_SelectionChanged">
                                    <ComboBoxItem Content="0.25x" Tag="0.25" />
                                    <ComboBoxItem Content="0.5x" Tag="0.5" />
                                    <ComboBoxItem Content="0.75x" Tag="0.75" />
                                    <ComboBoxItem Content="1x" Tag="1" IsSelected="True" />
                                    <ComboBoxItem Content="1.25x" Tag="1.25" />
                                    <ComboBoxItem Content="1.5x" Tag="1.5" />
                                    <ComboBoxItem Content="1.75x" Tag="1.75" />
                                    <ComboBoxItem Content="2x" Tag="2" />
                                </ComboBox>
                                <Button Name="MuteButton"
                                        Content="🔊"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Width="44"
                                        Height="40"
                                        Margin="0,0,10,10"
                                        Click="MuteButton_Click" />
                                <Slider Name="VolumeSlider"
                                        Width="110"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="0.8"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="False"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,10"
                                        ValueChanged="VolumeSlider_ValueChanged" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="PlaylistPanel"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="14"
                    CornerRadius="18"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Playlist"
                               Foreground="#E6F2FC"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <ListBox Name="PlaylistListBox"
                             Grid.Row="1"
                             Margin="0,12,0,12"
                             Background="Transparent"
                             Foreground="#EAF4FD"
                             SelectionChanged="PlaylistListBox_SelectionChanged"
                             MouseDoubleClick="PlaylistListBox_MouseDoubleClick"
                             AllowDrop="True"
                             Drop="PlaylistListBox_Drop" />
                    <WrapPanel Grid.Row="2" HorizontalAlignment="Left">
                        <Button Name="AddFilesToPlaylistButton"
                                Content="Add Files"
                                Style="{StaticResource TransportButtonStyle}"
                                Margin="0,0,8,0"
                                Click="AddFilesToPlaylistButton_Click" />
                        <Button Name="ClearPlaylistButton"
                                Content="Clear"
                                Style="{StaticResource TransportButtonStyle}"
                                Margin="0,0,8,0"
                                Click="ClearPlaylistButton_Click" />
                        <Button Name="RemovePlaylistItemButton"
                                Content="Remove"
                                Style="{StaticResource TransportButtonStyle}"
                                Click="RemovePlaylistItemButton_Click" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
