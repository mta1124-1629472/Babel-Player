<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:BabelPlayer.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="BabelPlayer.Avalonia.MainWindow"
        Title="Babel Player"
        DragDrop.AllowDrop="True"
        Width="1280"
        Height="720"
        Background="#111111">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <Border Grid.Row="0"
                Background="#191919"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel Spacing="10">
                <WrapPanel Orientation="Horizontal"
                           ItemHeight="32"
                           VerticalAlignment="Center">
                    <Button x:Name="OpenButton"
                            Content="Open Video"
                            Click="OpenButton_Click" />
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               Text="Open a local video to begin playback." />
                </WrapPanel>

                <WrapPanel Orientation="Horizontal"
                           ItemHeight="36"
                           VerticalAlignment="Center">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               Text="Transcription" />
                    <ComboBox x:Name="TranscriptionModelComboBox"
                              Width="280"
                              Margin="0,0,16,0"
                              SelectionChanged="TranscriptionModelComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:TranscriptionModelOption">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            ToolTip.Tip="{Binding AvailabilityHint}">
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" />
                                    <Border Background="#7A2E14"
                                            CornerRadius="6"
                                            Padding="6,2"
                                            IsVisible="{Binding ShowUnavailableIndicator}">
                                        <TextBlock Text="API key required"
                                                   Foreground="#FFD7CC"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               Text="Translation" />
                    <ComboBox x:Name="TranslationModelComboBox"
                              Width="300"
                              Margin="0,0,16,0"
                              SelectionChanged="TranslationModelComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:TranslationModelOption">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            ToolTip.Tip="{Binding AvailabilityHint}">
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" />
                                    <Border Background="{Binding BadgeBackground}"
                                            CornerRadius="6"
                                            Padding="6,2">
                                        <TextBlock Text="{Binding BadgeText}"
                                                   Foreground="{Binding BadgeForeground}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ToggleSwitch x:Name="AutoTranslateToggleSwitch"
                                  OffContent="Auto Translate Off"
                                  OnContent="Auto Translate On"
                                  Checked="AutoTranslateToggleSwitch_Changed"
                                  Unchecked="AutoTranslateToggleSwitch_Changed" />

                    <TextBlock Margin="16,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               Text="Subtitle Mode" />
                    <ComboBox x:Name="SubtitleModeComboBox"
                              Width="180"
                              SelectionChanged="SubtitleModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Off"
                                      Tag="Off" />
                        <ComboBoxItem Content="Source Only"
                                      Tag="SourceOnly" />
                        <ComboBoxItem Content="Translation Only"
                                      Tag="TranslationOnly" />
                        <ComboBoxItem Content="Dual"
                                      Tag="Dual" />
                    </ComboBox>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border x:Name="VideoSurfaceBorder"
                Grid.Row="1"
                Background="Black"
                CornerRadius="12"
                ClipToBounds="True">
            <local:MpvNativeHost x:Name="VideoHost" />
        </Border>

        <Border Grid.Row="2"
                Background="#191919"
                CornerRadius="12"
                Padding="12"
                Margin="0,12,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,120" RowDefinitions="Auto">
                <Button x:Name="PlayPauseButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        Content="Play"
                        Click="PlayPauseButton_Click" />
                <Button Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,12,0"
                        Content="Stop"
                        Click="StopButton_Click" />
                <Slider x:Name="TimelineSlider"
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="0,0,12,0"
                        Minimum="0"
                        Maximum="1"
                        Value="0"
                        VerticalAlignment="Center" />
                <TextBlock x:Name="PositionTextBlock"
                           Grid.Row="0"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="#F5F5F5"
                           Text="00:00 / 00:00" />
                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"
                           Foreground="#D0D0D0"
                           Text="Volume" />
                <Slider x:Name="VolumeSlider"
                        Grid.Row="0"
                        Grid.Column="5"
                        Minimum="0"
                        Maximum="1"
                        Value="0.8" />
            </Grid>
        </Border>
    </Grid>
</Window>
